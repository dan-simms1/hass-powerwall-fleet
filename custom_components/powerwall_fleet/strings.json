{
  "config": {
    "step": {
      "user": {
        "title": "Pick Tesla Fleet account",
        "description": "Choose which Tesla Fleet account hosts the Powerwall you want to bring local.",
        "data": {
          "parent_entry_id": "Tesla Fleet account"
        }
      },
      "pick_site": {
        "title": "Pick energy site",
        "description": "Select the energy site to configure. You can run this flow again to add another site.",
        "data": {
          "energy_site_id": "Energy site"
        }
      },
      "credentials": {
        "title": "Powerwall connection",
        "description": "Enter the **IP address** and **password** of the Powerwall at **{site_name}**. The password is printed **inside the Powerwall unit** (behind the front cover) — or ask Tesla support. Only the last 5 characters are used.",
        "data": {
          "gateway_host": "Powerwall IP address",
          "gateway_password": "Powerwall password"
        }
      },
      "pair": {
        "title": "Confirm at the Powerwall",
        "description": "Stand at the **Powerwall 3 unit itself** — not the Backup Gateway. On the **left-hand side** of the unit, flip the disconnect switch **off, then back on**, then click **Submit** to authorise the pairing key for **{site_name}**. (On a Powerwall 2 the switch is on the right-hand side.)"
      }
    },
    "error": {
      "pair_pending": "The Powerwall hasn't confirmed the key yet. At the unit, flip the left-hand disconnect switch off and back on, then click Submit again.",
